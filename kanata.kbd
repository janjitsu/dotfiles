(defcfg
  ;; Only target the internal laptop keyboard
  linux-dev-names-include ("AT Translated Set 2 keyboard")
  process-unmapped-keys yes
)


(defalias
  ;; Tap: Space | Hold: Left Control (timeout: 150ms)
  spc-ctrl (tap-hold 150 150 spc lctl)
)

(defalias
  ;; Tap: Enter | Hold: Left Shift (timeout: 150ms)
  ret-shift (tap-hold 150 150 ret lshift)
)

(defsrc
  spc ralt ro
)


(deflayer default
  @spc-ctrl @ret-shift ralt
)

