[a11y]
always-show-universal-access-status=true

[a11y/applications]
screen-magnifier-enabled=false

[a11y/interface]
high-contrast=false

[a11y/keyboard]
mousekeys-enable=false
stickykeys-enable=false

[a11y/magnifier]
cross-hairs-thickness=7
lens-mode=false
mouse-tracking='proportional'
screen-position='right-half'
show-cross-hairs=true

[app-folders]
folder-children=['Utilities', 'YaST']

[app-folders/folders/Utilities]
apps=['gnome-abrt.desktop', 'gnome-system-log.desktop', 'nm-connection-editor.desktop', 'org.gnome.baobab.desktop', 'org.gnome.Connections.desktop', 'org.gnome.DejaDup.desktop', 'org.gnome.Dictionary.desktop', 'org.gnome.DiskUtility.desktop', 'org.gnome.eog.desktop', 'org.gnome.Evince.desktop', 'org.gnome.FileRoller.desktop', 'org.gnome.fonts.desktop', 'org.gnome.seahorse.Application.desktop', 'org.gnome.tweaks.desktop', 'org.gnome.Usage.desktop', 'vinagre.desktop']
categories=['X-GNOME-Utilities']
name='X-GNOME-Utilities.directory'
translate=true

[app-folders/folders/YaST]
categories=['X-SuSE-YaST']
name='suse-yast.directory'
translate=true

[background]
color-shading-type='solid'
picture-options='zoom'
picture-uri='file:///home/janjitsu/Downloads/Deletar/background-naca-top-down.png'
picture-uri-dark='file:///usr/share/backgrounds/jj_dark_by_Hiking93.jpg'
primary-color='#000000'
secondary-color='#000000'

[calendar]
show-weekdate=false

[datetime]
automatic-timezone=false

[input-sources]
mru-sources=[('xkb', 'us+colemak'), ('xkb', 'me+cyrillic'), ('xkb', 'us'), ('xkb', 'latam+colemak-gaming')]
per-window=false
sources=[('xkb', 'me+cyrillic'), ('xkb', 'us+colemak'), ('xkb', 'us'), ('xkb', 'latam+colemak-gaming')]
xkb-options=['caps:backspace']

[interface]
color-scheme='prefer-dark'
cursor-size=96
document-font-name='Sans 10'
enable-hot-corners=true
font-hinting='none'
font-name='Ubuntu 10'
gtk-theme='Yaru-magenta-dark'
icon-theme='Yaru-magenta'
monospace-font-name='Ubuntu Mono 12'
show-battery-percentage=true
text-scaling-factor=1.1499999999999999
toolkit-accessibility=true

