[peripherals/keyboard]
delay=uint32 170
numlock-state=true
repeat-interval=uint32 10

[peripherals/mouse]
accel-profile='adaptive'
left-handed=false
speed=1.0

[peripherals/touchpad]
edge-scrolling-enabled=false
natural-scroll=false
speed=0.20588235294117641
tap-to-click=true
two-finger-scrolling-enabled=true

[privacy]
report-technical-problems=true

[remote-desktop/rdp]
enable=true
tls-cert='/home/janjitsu/.local/share/gnome-remote-desktop/rdp-tls.crt'
tls-key='/home/janjitsu/.local/share/gnome-remote-desktop/rdp-tls.key'

[remote-desktop/vnc]
enable=false

[screensaver]
color-shading-type='solid'
lock-delay=uint32 0
picture-options='zoom'
picture-uri='file:///usr/share/backgrounds/jj_dark_by_Hiking93.jpg'
primary-color='#000000'
secondary-color='#000000'

[session]
idle-delay=uint32 300

[sound]
event-sounds=true
theme-name='__custom'

