############################
# test/Dockerfile.arm-alpine
# Approximates a proot-distro Alpine container on ARM — the target for
# setup/arm/deps-apk.sh. No real aarch64 emulation is available in this
# environment, so this runs on the host's native architecture: it exercises
# package-manager detection, the dependency install list, symlinks, and
# vim/tmux plugin setup, not actual ARM binaries.
#
# Unlike the Ubuntu/Fedora desktop tests, setup/arm.sh never touches
# systemd, so this container needs no --privileged/systemd bootstrapping.
#
# Built and run via test/test.sh — not meant to be used standalone.
############################

FROM alpine:latest

RUN apk add --no-cache bash

COPY . /root/dotfiles

CMD ["/bin/bash"]
